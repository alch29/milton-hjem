{
    "source": {
        "include": ["src/stores", "src/composables", "src/config", "src/router"],
        "includePattern": ".js$",
        "excludePattern": "(__tests__|.test).js$"
    },
    "opts": {
        "destination": "./docs",
        "recurse": true,
        "tutorials": "./tutorials",
        "template": "./themes/docdash"
    },
    "docdash": {
        "tutorialsLabel": "Guides",
        "modulesLabel": "Modules"
    }
}
